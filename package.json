{
  "name": "@lerna-labs/ekklesia-helpers",
  "version": "1.1.1",
  "description": "Shared helper functions for the Ekklesia platform",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "import": "./dist/validation/index.js"
    },
    "./crypto": {
      "types": "./dist/crypto/index.d.ts",
      "import": "./dist/crypto/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    },
    "./cardano": {
      "types": "./dist/cardano/index.d.ts",
      "import": "./dist/cardano/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./json": {
      "types": "./dist/json/index.d.ts",
      "import": "./dist/json/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint --fix . && prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:live": "LIVE_TEST=true vitest run --reporter=verbose",
    "docs": "typedoc",
    "docs:serve": "typedoc && npx serve docs",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "npm run build && changeset publish",
    "changeset:snapshot": "changeset version --snapshot rc"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lerna-labs/ekklesia-helpers.git"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@emurgo/cardano-serialization-lib-nodejs": "^12.0.0",
    "bech32": "^2.0.0",
    "blakejs": "^1.2.0",
    "cbor": "^10.0.12",
    "dotenv": "^17.3.1",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^9.2.4"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@eslint/js": "^9.39.5",
    "@types/jsonwebtoken": "^9.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "jiti": "^2.7.0",
    "prettier": "^3.9.5",
    "typedoc": "^0.28.20",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
